# Lucky Spins Casino App - Environment Configuration Template
# Copy this file to .env and fill in your values

# Required: Database connection (PostgreSQL)
# Example: postgresql://user:password@host:port/database
DATABASE_URL=

# Required: JWT secret for session signing
JWT_SECRET=change-me-in-production

# Required: OAuth App ID
VITE_APP_ID=lucky-spins-dev

# Required: OAuth server URL
OAUTH_SERVER_URL=http://localhost:3000

# Optional: Admin owner OpenID
OWNER_OPEN_ID=owner

# Optional: AI/Forge API services
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional: Square payment processing
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=L2N0S3FA7EX8B
VITE_SQUARE_APP_ID=

# Node environment
NODE_ENV=development
PORT=3000
